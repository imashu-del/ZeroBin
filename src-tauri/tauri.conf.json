{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZeroBin",
  "version": "0.1.0",
  "identifier": "com.zerobin.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZeroBin",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/7za"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/imashu-del/ZeroBin/refs/heads/main/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5NTM0NDk0QTBGQzg3Q0QKUldUTmgveWdsRVJUbVY5R0lReDBOdlZzeDYrTmp3WXpGazhWRktXcnViOVBiaStlSEZYZVZkNGYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
